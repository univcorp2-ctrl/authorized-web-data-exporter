KENBIYA_EMAIL="your-email@example.com"
KENBIYA_PASSWORD="your-password"
WEB_EXPORT_ACKNOWLEDGE_AUTHORIZED="true"

# 不動産情報ライブラリAPIキーは表示・保存しません。
# ローカルWindowsでは下記Excelファイルを標準探索します。
REINFOLIB_API_KEY_XLSX_PATH="G:\\マイドライブ\\AI_Agents\\Private\\API_AWS_DB.xlsx"

# GitHub ActionsなどExcelファイルを読めない環境ではRepository SecretとしてREINFOLIB_API_KEYを設定できます。
# REINFOLIB_API_KEY=""

# Optional: newline-separated start URLs. Profile start_urls is usually easier.
# WEB_EXPORT_START_URLS="https://www.kenbiya.com/...\nhttps://www.kenbiya.com/..."
